rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students can only read/write their own profile. Teachers are scoped to
    // students in the teacher's assigned department and academic year.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if teacherCanAccessExistingDepartment();
      allow create: if request.auth != null
        && (request.auth.uid == userId || teacherCanAccessNewDepartment())
        && request.resource.data.role == 'student'
        && validStudentProfileCreate(userId)
        && validDepartment(request.resource.data.department)
        && validYear(request.resource.data.year)
        && validRegisterNumber(request.resource.data.registerNumber);
      allow update: if request.auth != null
        && (request.auth.uid == userId || teacherCanAccessExistingAndNewDepartment())
        && validStudentProfileUpdate(userId)
        && validDepartment(request.resource.data.department)
        && validYear(request.resource.data.year)
        && validRegisterNumber(request.resource.data.registerNumber)
        && request.resource.data.role == resource.data.role
        && (request.resource.data.email == resource.data.email || request.auth.uid == userId)
        && request.resource.data.registerNumber == resource.data.registerNumber;
      allow delete: if teacherCanAccessExistingDepartment();
    }

    // Teachers can read faculty records, but only update their own document
    match /teachers/{teacherId} {
      allow read: if request.auth != null && request.auth.uid == teacherId;
      allow create: if request.auth != null
        && request.auth.uid == teacherId
        && request.resource.data.role == 'teacher'
        && validTeacherProfileCreate()
        && validDepartment(request.resource.data.department)
        && validYear(request.resource.data.year);
      allow update: if request.auth != null
        && request.auth.uid == teacherId
        && validTeacherProfileUpdate()
        && validDepartment(request.resource.data.department)
        && validYear(request.resource.data.year)
        && request.resource.data.role == resource.data.role
        && (request.resource.data.email == resource.data.email || request.auth.uid == teacherId);
      allow delete: if false;
    }

    // Function to check if the user is a teacher
    function isTeacher() {
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    function teacherProfile() {
      return get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data;
    }

    function teacherDepartment() {
      return teacherProfile().department;
    }

    function teacherYear() {
      return teacherProfile().year;
    }

    function teacherCanAccessExistingDepartment() {
      return isTeacher()
        && resource.data.department == teacherDepartment()
        && resource.data.year == teacherYear();
    }

    function teacherCanAccessNewDepartment() {
      return isTeacher()
        && request.resource.data.department == teacherDepartment()
        && request.resource.data.year == teacherYear();
    }

    function teacherCanAccessExistingAndNewDepartment() {
      return teacherCanAccessExistingDepartment()
        && request.resource.data.department == teacherDepartment()
        && request.resource.data.year == teacherYear();
    }

    function validDepartment(department) {
      return department in [
        'B.Sc Computer Science (BSC CS)',
        'Artificial Intelligence & Machine Learning (AI & ML)',
        'B.Com',
        'MBA',
        'Information Technology (IT)',
        'Computer Science & Data Analytics (CSDA)',
        'Catering Science & Hotel Management (CS & HM)',
        'BBA',
        'B.Com Professional Accounting (BCOM PA)',
        'B.Com Information Technology (BCOM IT)'
      ];
    }

    function validYear(year) {
      return year in ['I', 'II', 'III'];
    }

    function validRegisterNumber(registerNumber) {
      return registerNumber is string && registerNumber.size() > 0;
    }

    function validStudentProfileCreate(userId) {
      return request.resource.data.keys().hasAll([
        'uid',
        'fullName',
        'email',
        'registerNumber',
        'phone',
        'department',
        'year',
        'role',
        'status',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'uid',
        'fullName',
        'email',
        'registerNumber',
        'department',
        'year',
        'phone',
        'mobile',
        'studentId',
        'status',
        'role',
        'createdBy',
        'profilePhotoUrl',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.uid is string
      && request.resource.data.uid == userId
      && request.resource.data.fullName is string
      && request.resource.data.email is string
      && request.resource.data.uid.size() > 0
      && request.resource.data.fullName.size() > 0
      && request.resource.data.email.size() > 0
      && validStudentStatus(request.resource.data.status);
    }

    function validStudentProfileUpdate(userId) {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && validStudentProfileCreate(userId);
    }

    function validTeacherProfileCreate() {
      return request.resource.data.keys().hasAll([
        'uid',
        'fullName',
        'email',
        'department',
        'year',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'uid',
        'fullName',
        'email',
        'department',
        'year',
        'phone',
        'teacherId',
        'role',
        'profilePhotoUrl',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.fullName is string
      && request.resource.data.email is string
      && request.resource.data.fullName.size() > 0
      && request.resource.data.email.size() > 0;
    }

    function validTeacherProfileUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && validTeacherProfileCreate();
    }

    function validStudentStatus(status) {
      return status in ['active', 'inactive', 'pending'];
    }

    function validAcademicDocumentType(title) {
      return title in [
        'Aadhaar Card',
        'Income Certificate',
        'Community Certificate',
        '10th Marksheet',
        '12th Marksheet',
        'Bank Passbook'
      ];
    }

    function ownsExistingStudentDoc() {
      return request.auth != null && resource.data.studentUid == request.auth.uid;
    }

    function ownsNewStudentDoc() {
      return request.auth != null && request.resource.data.studentUid == request.auth.uid;
    }

    function existingDocMatchesOwnerDepartment() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && resource.data.department == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }

    function newDocMatchesOwnerDepartment() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && request.resource.data.department == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }

    function teacherCanAccessExistingDocDepartment() {
      return isTeacher()
        && resource.data.department == teacherDepartment()
        && resource.data.year == teacherYear();
    }

    function teacherCanAccessNewDocDepartment() {
      return isTeacher()
        && request.resource.data.department == teacherDepartment()
        && request.resource.data.year == teacherYear();
    }

    function teacherCanAccessExistingAndNewDocDepartment() {
      return teacherCanAccessExistingDocDepartment()
        && request.resource.data.department == teacherDepartment()
        && request.resource.data.year == teacherYear();
    }

    function validNewDocumentCommon(category) {
      return request.resource.data.category == category
        && request.resource.data.studentUid is string
        && request.resource.data.department is string
        && request.resource.data.year is string
        && request.resource.data.title is string
        && request.resource.data.fileName is string
        && request.resource.data.fileUrl is string
        && (!('status' in request.resource.data) || request.resource.data.status in ['uploaded', 'verified', 'rejected', 'pending'])
        && validDepartment(request.resource.data.department)
        && validYear(request.resource.data.year);
    }

    function validUpdatedDocumentCommon() {
      return request.resource.data.studentUid == resource.data.studentUid
        && request.resource.data.department == resource.data.department
        && request.resource.data.year == resource.data.year
        && request.resource.data.category == resource.data.category
        && request.resource.data.storagePath == resource.data.storagePath;
    }

    // Rules for student-specific collections
    match /onlineCertificates/{docId} {
      allow read, delete: if ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment();
      allow create: if ownsNewStudentDoc() && newDocMatchesOwnerDepartment() && validNewDocumentCommon('Online Certificates');
      allow update: if ownsExistingStudentDoc() && ownsNewStudentDoc() && existingDocMatchesOwnerDepartment() && newDocMatchesOwnerDepartment() && validUpdatedDocumentCommon();
    }

    match /offlineCertificates/{docId} {
      allow read, delete: if ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment();
      allow create: if ownsNewStudentDoc() && newDocMatchesOwnerDepartment() && validNewDocumentCommon('Offline Certificates');
      allow update: if ownsExistingStudentDoc() && ownsNewStudentDoc() && existingDocMatchesOwnerDepartment() && newDocMatchesOwnerDepartment() && validUpdatedDocumentCommon();
    }

    match /academicCertificates/{docId} {
      allow read: if (ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment()) || teacherCanAccessExistingDocDepartment();
      allow delete: if ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment();
      allow create: if ownsNewStudentDoc()
        && newDocMatchesOwnerDepartment()
        && validNewDocumentCommon('Academic Certificates')
        && validAcademicDocumentType(request.resource.data.title);
      allow update: if ownsExistingStudentDoc()
        && ownsNewStudentDoc()
        && existingDocMatchesOwnerDepartment()
        && newDocMatchesOwnerDepartment()
        && validUpdatedDocumentCommon()
        && validAcademicDocumentType(request.resource.data.title);
    }

    match /personalDocuments/{docId} {
      allow read, delete: if ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment();
      allow create: if ownsNewStudentDoc() && newDocMatchesOwnerDepartment() && validNewDocumentCommon('Personal Documents');
      allow update: if ownsExistingStudentDoc() && ownsNewStudentDoc() && existingDocMatchesOwnerDepartment() && newDocMatchesOwnerDepartment() && validUpdatedDocumentCommon();
    }

    match /activityLogs/{docId} {
      allow read, delete: if (ownsExistingStudentDoc() && existingDocMatchesOwnerDepartment()) || teacherCanAccessExistingDocDepartment();
      allow create: if (ownsNewStudentDoc() && newDocMatchesOwnerDepartment()) || teacherCanAccessNewDocDepartment();
      allow update: if (ownsExistingStudentDoc() && ownsNewStudentDoc() && existingDocMatchesOwnerDepartment() && newDocMatchesOwnerDepartment()) || teacherCanAccessExistingAndNewDocDepartment();
    }
  }
}
